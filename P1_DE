<div class="section" id="section-step8">
  <div class="hero">
    <div class="hero-tag">Step 8 · Data Quality</div>
    <h1>Data Quality Framework</h1>
    <p>Standalone quality checks that generate a JSON report. Run this after ETL to catch issues before analysts hit bad data.</p>
  </div>

  <div class="code-block">
    <div class="code-header"><span class="code-lang">scripts/data_quality.py</span><button class="copy-btn" onclick="copyCode(this)">Copy</button></div>
    <pre><code><span class="cm">"""
Standalone data quality checks. Run after ETL to validate output.
Generates: data/quality_report.json
"""</span>
<span class="kw">from</span> pyspark.sql <span class="kw">import</span> SparkSession
<span class="kw">from</span> pyspark.sql <span class="kw">import</span> functions <span class="kw">as</span> F
<span class="kw">import</span> json
<span class="kw">from</span> datetime <span class="kw">import</span> datetime

spark <span class="op">=</span> SparkSession.builder.master(<span class="st">"local[*]"</span>).appName(<span class="st">"dq"</span>).getOrCreate()
spark.sparkContext.setLogLevel(<span class="st">"WARN"</span>)

<span class="kw">def</span> <span class="fn">check_completeness</span>(df, columns):
    <span class="st">"""Check null % for each column. Fails if > 5% nulls."""</span>
    total <span class="op">=</span> df.count()
    results <span class="op">=</span> {}
    <span class="kw">for</span> col <span class="kw">in</span> columns:
        nulls <span class="op">=</span> df.filter(F.col(col).isNull()).count()
        results[col] <span class="op">=</span> {
            <span class="st">"null_count"</span>: nulls,
            <span class="st">"null_pct"</span>:   round(nulls <span class="op">/</span> total <span class="op">*</span> <span class="nm">100</span>, <span class="nm">2</span>),
            <span class="st">"passed"</span>:     nulls <span class="op">/</span> total <span class="op"><</span> <span class="nm">0.05</span>,
        }
    <span class="kw">return</span> results

<span class="kw">def</span> <span class="fn">check_uniqueness</span>(df, columns):
    <span class="st">"""Check for duplicates in key columns."""</span>
    total <span class="op">=</span> df.count()
    results <span class="op">=</span> {}
    <span class="kw">for</span> col <span class="kw">in</span> columns:
        distinct <span class="op">=</span> df.select(col).distinct().count()
        results[col] <span class="op">=</span> {
            <span class="st">"dupes"</span>:  total <span class="op">-</span> distinct,
            <span class="st">"passed"</span>: (total <span class="op">-</span> distinct) <span class="op">==</span> <span class="nm">0</span>,
        }
    <span class="kw">return</span> results

<span class="kw">def</span> <span class="fn">check_referential_integrity</span>(child_df, parent_df, child_key, parent_key):
    <span class="st">"""Check all FK values exist in parent table (no orphans)."""</span>
    orphans <span class="op">=</span> (child_df.select(child_key)
        .join(parent_df.select(parent_key),
              child_df[child_key] <span class="op">==</span> parent_df[parent_key], <span class="st">"left_anti"</span>)
        .count())
    <span class="kw">return</span> {<span class="st">"orphan_rows"</span>: orphans, <span class="st">"passed"</span>: orphans <span class="op">==</span> <span class="nm">0</span>}

<span class="kw">if</span> __name__ <span class="op">==</span> <span class="st">"__main__"</span>:
    fact  <span class="op">=</span> spark.read.parquet(<span class="st">"data/processed/fact_orders"</span>)
    dim_c <span class="op">=</span> spark.read.parquet(<span class="st">"data/processed/dim_customer"</span>) <span class="kw">if</span> __import__(<span class="st">'os'</span>).path.exists(<span class="st">"data/processed/dim_customer"</span>) <span class="kw">else</span> <span class="kw">None</span>

    checks <span class="op">=</span> {
        <span class="st">"completeness"</span>: check_completeness(fact, [<span class="st">"order_key"</span>, <span class="st">"customer_key"</span>, <span class="st">"net_revenue"</span>]),
        <span class="st">"uniqueness"</span>:   check_uniqueness(fact, [<span class="st">"order_id"</span>]),
    }

    report <span class="op">=</span> {
        <span class="st">"run_at"</span>:        datetime.utcnow().isoformat(),
        <span class="st">"checks"</span>:        checks,
        <span class="st">"overall_passed"</span>: <span class="kw">all</span>(
            v.get(<span class="st">"passed"</span>, <span class="kw">True</span>)
            <span class="kw">for</span> section <span class="kw">in</span> checks.values()
            <span class="kw">for</span> v <span class="kw">in</span> section.values()
        )
    }
    <span class="kw">with</span> open(<span class="st">"data/quality_report.json"</span>, <span class="st">"w"</span>) <span class="kw">as</span> f:
        json.dump(report, f, indent<span class="op">=</span><span class="nm">2</span>)

    status <span class="op">=</span> <span class="st">"✅ PASSED"</span> <span class="kw">if</span> report[<span class="st">"overall_passed"</span>] <span class="kw">else</span> <span class="st">"❌ FAILED"</span>
    print(<span class="st">f"Data Quality: {status}"</span>)
    print(<span class="st">"Report saved to data/quality_report.json"</span>)</code></pre>
