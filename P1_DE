<!-- ════ OVERVIEW ════ -->
<div class="section active" id="section-overview">
  <div class="hero">
    <div class="hero-tag">Project 01 · Level 1→2 · E-commerce Industry</div>
    <h1>Order Analytics Pipeline</h1>
    <p>Build a batch ETL pipeline that consolidates scattered order data into a star schema data warehouse — enabling analysts to answer business questions in under an hour instead of 3–4 days.</p>
