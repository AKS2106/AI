<div class="section" id="section-step5">
  <div class="hero">
    <div class="hero-tag">Step 5 · S3 Ingestion</div>
    <h1>Upload Raw Data to S3</h1>
    <p>Upload your generated files to the S3 raw zone with proper folder structure and metadata tagging.</p>
  </div>

  <div class="callout callout-warn">
    <div class="callout-icon">⚠️</div>
    <div>Change <code>BUCKET_NAME</code> in the script to something unique — like <code>ecom-pipeline-yourname-2024</code>. S3 bucket names are globally unique across all AWS accounts.</div>
  </div>

  <div class="code-block">
    <div class="code-header"><span class="code-lang">scripts/upload_to_s3.py</span><button class="copy-btn" onclick="copyCode(this)">Copy</button></div>
    <pre><code><span class="cm">"""
Ingestion script: upload raw local files to S3 raw zone.
In production this would be triggered by Lambda or an Airflow DAG.
"""</span>
<span class="kw">import</span> boto3, os, sys
<span class="kw">from</span> datetime <span class="kw">import</span> datetime

BUCKET_NAME <span class="op">=</span> <span class="st">"ecom-pipeline-yourname-2024"</span>  <span class="cm"># ← CHANGE THIS</span>
AWS_REGION  <span class="op">=</span> <span class="st">"us-east-1"</span>

s3 <span class="op">=</span> boto3.client(<span class="st">"s3"</span>, region_name<span class="op">=</span>AWS_REGION)

<span class="kw">def</span> <span class="fn">create_bucket</span>():
    <span class="kw">try</span>:
        s3.head_bucket(Bucket<span class="op">=</span>BUCKET_NAME)
        print(<span class="st">f"Bucket {BUCKET_NAME} exists"</span>)
    <span class="kw">except</span>:
        s3.create_bucket(Bucket<span class="op">=</span>BUCKET_NAME)
        s3.put_bucket_versioning(
            Bucket<span class="op">=</span>BUCKET_NAME,
            VersioningConfiguration<span class="op">=</span>{<span class="st">"Status"</span>: <span class="st">"Enabled"</span>}
        )
        print(<span class="st">f"Created bucket {BUCKET_NAME} with versioning ✓"</span>)

<span class="kw">def</span> <span class="fn">upload_file</span>(local_path, s3_key):
    s3.upload_file(
        Filename<span class="op">=</span>local_path, Bucket<span class="op">=</span>BUCKET_NAME, Key<span class="op">=</span>s3_key,
        ExtraArgs<span class="op">=</span>{<span class="st">"Metadata"</span>: {
            <span class="st">"upload_timestamp"</span>: datetime.utcnow().isoformat(),
            <span class="st">"pipeline_version"</span>: <span class="st">"1.0"</span>,
        }}
    )
    print(<span class="st">f"  ✓ {local_path} → s3://{BUCKET_NAME}/{s3_key}"</span>)

<span class="kw">def</span> <span class="fn">main</span>():
    create_bucket()
    uploads <span class="op">=</span> [
        (<span class="st">"data/raw/orders/orders_2024.csv"</span>,
         <span class="st">"raw/orders/year=2024/month=01/day=01/orders_2024.csv"</span>),
        (<span class="st">"data/raw/returns/returns_2024.json"</span>,
         <span class="st">"raw/returns/year=2024/month=01/day=01/returns_2024.json"</span>),
        (<span class="st">"data/raw/events/events_2024.json"</span>,
         <span class="st">"raw/events/year=2024/month=01/day=01/events_2024.json"</span>),
    ]
    print(<span class="st">f"\nUploading {len(uploads)} files..."</span>)
    <span class="kw">for</span> local_path, s3_key <span class="kw">in</span> uploads:
        <span class="kw">if</span> os.path.exists(local_path):
            upload_file(local_path, s3_key)
        <span class="kw">else</span>:
            print(<span class="st">f"  ✗ Not found: {local_path}"</span>); sys.exit(<span class="nm">1</span>)
    print(<span class="st">"\n✅ Upload complete!"</span>)

<span class="kw">if</span> __name__ <span class="op">==</span> <span class="st">"__main__"</span>:
    main()</code></pre>
  </div>

