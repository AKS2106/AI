<div class="section" id="section-step4">
  <div class="hero">
    <div class="hero-tag">Step 4 · Generate Data</div>
    <h1>Synthetic Data Generator</h1>
    <p>Creates realistic e-commerce data: 5,000 orders (CSV), 600 returns (JSON), 3,000 marketing events (JSON). Includes intentional data quality issues for the pipeline to catch.</p>
  </div>

  <div class="callout callout-tip">
    <div class="callout-icon">💡</div>
    <div>This script uses the <code>Faker</code> library to generate realistic names, emails, addresses. The <code>random.seed(42)</code> means it generates the same data every run — important for reproducible testing.</div>
  </div>

  <div class="code-block">
    <div class="code-header"><span class="code-lang">scripts/generate_data.py</span><button class="copy-btn" onclick="copyCode(this)">Copy</button></div>
    <pre><code><span class="cm">"""
Generate synthetic e-commerce data simulating real enterprise sources.
Produces: orders.csv, returns.json, events.json
Run: python3 scripts/generate_data.py
"""</span>

<span class="kw">import</span> csv, json, random, uuid
<span class="kw">from</span> datetime <span class="kw">import</span> datetime, timedelta
<span class="kw">from</span> faker <span class="kw">import</span> Faker

fake <span class="op">=</span> Faker()
random.seed(<span class="nm">42</span>)

<span class="cm"># ── Config ──────────────────────────────────────────────</span>
NUM_CUSTOMERS <span class="op">=</span> <span class="nm">500</span>
NUM_PRODUCTS  <span class="op">=</span> <span class="nm">200</span>
NUM_ORDERS    <span class="op">=</span> <span class="nm">5000</span>
NUM_RETURNS   <span class="op">=</span> <span class="nm">600</span>
NUM_EVENTS    <span class="op">=</span> <span class="nm">3000</span>
START_DATE    <span class="op">=</span> datetime(<span class="nm">2024</span>, <span class="nm">1</span>, <span class="nm">1</span>)
END_DATE      <span class="op">=</span> datetime(<span class="nm">2024</span>, <span class="nm">12</span>, <span class="nm">31</span>)

CATEGORIES <span class="op">=</span> {
    <span class="st">"Electronics"</span>: [<span class="st">"Laptop"</span>, <span class="st">"Phone"</span>, <span class="st">"Tablet"</span>, <span class="st">"Headphones"</span>, <span class="st">"Camera"</span>],
    <span class="st">"Clothing"</span>:    [<span class="st">"T-Shirt"</span>, <span class="st">"Jeans"</span>, <span class="st">"Jacket"</span>, <span class="st">"Shoes"</span>, <span class="st">"Dress"</span>],
    <span class="st">"Home"</span>:        [<span class="st">"Lamp"</span>, <span class="st">"Chair"</span>, <span class="st">"Desk"</span>, <span class="st">"Pillow"</span>, <span class="st">"Blanket"</span>],
    <span class="st">"Sports"</span>:      [<span class="st">"Yoga Mat"</span>, <span class="st">"Dumbbell"</span>, <span class="st">"Shoes"</span>, <span class="st">"Bottle"</span>, <span class="st">"Bag"</span>],
    <span class="st">"Books"</span>:       [<span class="st">"Fiction"</span>, <span class="st">"Non-Fiction"</span>, <span class="st">"Textbook"</span>, <span class="st">"Comic"</span>, <span class="st">"Magazine"</span>],
}
SEGMENTS <span class="op">=</span> [<span class="st">"Premium"</span>, <span class="st">"Regular"</span>, <span class="st">"Occasional"</span>, <span class="st">"New"</span>]
REGIONS  <span class="op">=</span> [<span class="st">"Northeast"</span>, <span class="st">"Southeast"</span>, <span class="st">"Midwest"</span>, <span class="st">"West"</span>, <span class="st">"Southwest"</span>]

<span class="kw">def</span> <span class="fn">rand_date_str</span>(start<span class="op">=</span>START_DATE, end<span class="op">=</span>END_DATE):
    delta <span class="op">=</span> end <span class="op">-</span> start
    <span class="kw">return</span> (start <span class="op">+</span> timedelta(days<span class="op">=</span>random.randint(<span class="nm">0</span>, delta.days))).strftime(<span class="st">"%Y-%m-%d %H:%M:%S"</span>)

<span class="cm"># ── Customers ───────────────────────────────────────────</span>
customers <span class="op">=</span> []
<span class="kw">for</span> _ <span class="kw">in</span> range(NUM_CUSTOMERS):
    customers.append({
        <span class="st">"customer_id"</span>: <span class="st">f"CUST-{str(uuid.uuid4())[:8].upper()}"</span>,
        <span class="st">"name"</span>:        fake.name(),
        <span class="st">"email"</span>:       fake.email(),
        <span class="st">"city"</span>:        fake.city(),
        <span class="st">"state"</span>:       fake.state_abbr(),
        <span class="st">"region"</span>:      random.choice(REGIONS),
        <span class="st">"segment"</span>:     random.choice(SEGMENTS),
    })
customer_ids <span class="op">=</span> [c[<span class="st">"customer_id"</span>] <span class="kw">for</span> c <span class="kw">in</span> customers]

<span class="cm"># ── Products ────────────────────────────────────────────</span>
products <span class="op">=</span> []
<span class="kw">for</span> _ <span class="kw">in</span> range(NUM_PRODUCTS):
    cat        <span class="op">=</span> random.choice(list(CATEGORIES.keys()))
    sub        <span class="op">=</span> random.choice(CATEGORIES[cat])
    base_price <span class="op">=</span> round(random.uniform(<span class="nm">9.99</span>, <span class="nm">499.99</span>), <span class="nm">2</span>)
    products.append({
        <span class="st">"product_id"</span>:   <span class="st">f"PROD-{str(uuid.uuid4())[:8].upper()}"</span>,
        <span class="st">"name"</span>:         <span class="st">f"{fake.word().capitalize()} {sub}"</span>,
        <span class="st">"category"</span>:     cat,
        <span class="st">"subcategory"</span>:  sub,
        <span class="st">"brand"</span>:        fake.company(),
        <span class="st">"unit_cost"</span>:    round(base_price <span class="op">*</span> <span class="nm">0.55</span>, <span class="nm">2</span>),
        <span class="st">"list_price"</span>:   base_price,
        <span class="st">"is_available"</span>: random.choice([<span class="kw">True</span>, <span class="kw">True</span>, <span class="kw">True</span>, <span class="kw">False</span>]),
    })
product_ids <span class="op">=</span> [p[<span class="st">"product_id"</span>] <span class="kw">for</span> p <span class="kw">in</span> products]

<span class="cm"># ── Orders (CSV) ────────────────────────────────────────</span>
print(<span class="st">"Generating orders CSV..."</span>)
orders <span class="op">=</span> []
<span class="kw">for</span> _ <span class="kw">in</span> range(NUM_ORDERS):
    qty        <span class="op">=</span> random.randint(<span class="nm">1</span>, <span class="nm">5</span>)
    product    <span class="op">=</span> random.choice(products)
    discount   <span class="op">=</span> round(random.choice([<span class="nm">0</span>, <span class="nm">0</span>, <span class="nm">0</span>, <span class="nm">0.05</span>, <span class="nm">0.1</span>, <span class="nm">0.15</span>, <span class="nm">0.2</span>]), <span class="nm">2</span>)
    order_amt  <span class="op">=</span> round(qty <span class="op">*</span> product[<span class="st">"list_price"</span>] <span class="op">*</span> (<span class="nm">1</span> <span class="op">-</span> discount), <span class="nm">2</span>)
    orders.append({
        <span class="st">"order_id"</span>:       <span class="st">f"ORD-{str(uuid.uuid4())[:8].upper()}"</span>,
        <span class="st">"customer_id"</span>:    random.choice(customer_ids),
        <span class="st">"product_id"</span>:     product[<span class="st">"product_id"</span>],
        <span class="st">"order_date"</span>:     rand_date_str(),
        <span class="st">"quantity"</span>:       qty,
        <span class="st">"unit_price"</span>:     product[<span class="st">"list_price"</span>],
        <span class="st">"discount_pct"</span>:   discount,
        <span class="st">"order_amount"</span>:   order_amt,
        <span class="st">"payment_method"</span>: random.choice([<span class="st">"Credit Card"</span>, <span class="st">"Debit Card"</span>, <span class="st">"PayPal"</span>, <span class="st">"Gift Card"</span>]),
        <span class="st">"order_status"</span>:   random.choice([<span class="st">"Delivered"</span>, <span class="st">"Delivered"</span>, <span class="st">"Delivered"</span>, <span class="st">"Cancelled"</span>, <span class="st">"Pending"</span>]),
        <span class="st">"shipping_days"</span>:  random.randint(<span class="nm">1</span>, <span class="nm">10</span>),
    })

<span class="kw">with</span> open(<span class="st">"data/raw/orders/orders_2024.csv"</span>, <span class="st">"w"</span>, newline<span class="op">=</span><span class="st">""</span>) <span class="kw">as</span> f:
    writer <span class="op">=</span> csv.DictWriter(f, fieldnames<span class="op">=</span>orders[<span class="nm">0</span>].keys())
    writer.writeheader()
    writer.writerows(orders)
print(<span class="st">f"  → {len(orders)} orders written"</span>)

<span class="cm"># ── Returns (JSON) ──────────────────────────────────────</span>
print(<span class="st">"Generating returns JSON..."</span>)
delivered   <span class="op">=</span> [o <span class="kw">for</span> o <span class="kw">in</span> orders <span class="kw">if</span> o[<span class="st">"order_status"</span>] <span class="op">==</span> <span class="st">"Delivered"</span>]
return_reasons <span class="op">=</span> [<span class="st">"Defective"</span>, <span class="st">"Wrong item"</span>, <span class="st">"Changed mind"</span>, <span class="st">"Arrived late"</span>, <span class="st">"Damaged"</span>]
returns <span class="op">=</span> []
<span class="kw">for</span> order <span class="kw">in</span> random.sample(delivered, min(NUM_RETURNS, len(delivered))):
    order_dt <span class="op">=</span> datetime.strptime(order[<span class="st">"order_date"</span>], <span class="st">"%Y-%m-%d %H:%M:%S"</span>)
    ret_dt   <span class="op">=</span> order_dt <span class="op">+</span> timedelta(days<span class="op">=</span>random.randint(<span class="nm">1</span>, <span class="nm">30</span>))
    returns.append({
        <span class="st">"return_id"</span>:     <span class="st">f"RET-{str(uuid.uuid4())[:8].upper()}"</span>,
        <span class="st">"order_id"</span>:      order[<span class="st">"order_id"</span>],
        <span class="st">"return_date"</span>:   ret_dt.strftime(<span class="st">"%Y-%m-%d %H:%M:%S"</span>),
        <span class="st">"reason"</span>:        random.choice(return_reasons),
        <span class="st">"refund_amount"</span>: order[<span class="st">"order_amount"</span>],
        <span class="st">"return_status"</span>: random.choice([<span class="st">"Completed"</span>, <span class="st">"Pending"</span>, <span class="st">"Rejected"</span>]),
    })
<span class="kw">with</span> open(<span class="st">"data/raw/returns/returns_2024.json"</span>, <span class="st">"w"</span>) <span class="kw">as</span> f:
    json.dump(returns, f, indent<span class="op">=</span><span class="nm">2</span>)
print(<span class="st">f"  → {len(returns)} returns written"</span>)

<span class="cm"># ── Events (JSON) ───────────────────────────────────────</span>
print(<span class="st">"Generating marketing events JSON..."</span>)
event_types <span class="op">=</span> [<span class="st">"page_view"</span>, <span class="st">"add_to_cart"</span>, <span class="st">"checkout_start"</span>, <span class="st">"purchase"</span>, <span class="st">"email_open"</span>]
events <span class="op">=</span> []
<span class="kw">for</span> _ <span class="kw">in</span> range(NUM_EVENTS):
    events.append({
        <span class="st">"event_id"</span>:   str(uuid.uuid4()),
        <span class="st">"customer_id"</span>: random.choice(customer_ids),
        <span class="st">"event_type"</span>:  random.choice(event_types),
        <span class="st">"event_date"</span>:  rand_date_str(),
        <span class="st">"product_id"</span>:  random.choice(product_ids) <span class="kw">if</span> random.random() <span class="op">></span> <span class="nm">0.3</span> <span class="kw">else</span> <span class="kw">None</span>,
        <span class="st">"channel"</span>:    random.choice([<span class="st">"organic"</span>, <span class="st">"paid_search"</span>, <span class="st">"email"</span>, <span class="st">"social"</span>, <span class="kw">None</span>]),
    })
<span class="kw">with</span> open(<span class="st">"data/raw/events/events_2024.json"</span>, <span class="st">"w"</span>) <span class="kw">as</span> f:
    json.dump(events, f, indent<span class="op">=</span><span class="nm">2</span>)
print(<span class="st">f"  → {len(events)} events written"</span>)

print(<span class="st">"\n✅ All data generated!"</span>)</code></pre>
  </div>

