<!-- ════ STEP 7 ════ -->
<div class="section" id="section-step7">
  <div class="hero">
    <div class="hero-tag">Step 7 · SQL Queries</div>
    <h1>Analytical SQL — Interview Level</h1>
    <p>Four complex queries covering window functions, CTEs, cohort analysis, and ranking. These exact patterns appear in Data Engineer interviews.</p>
  </div>

  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab(this,'q1')">Monthly Revenue</button>
    <button class="tab-btn" onclick="switchTab(this,'q2')">Cohort Retention</button>
    <button class="tab-btn" onclick="switchTab(this,'q3')">Category Ranking</button>
    <button class="tab-btn" onclick="switchTab(this,'q4')">Churn Risk</button>
  </div>

  <div class="tab-panel active" id="tab-q1">
    <div class="callout callout-info">
      <div class="callout-icon">💡</div>
      <div><strong>What this shows:</strong> Month-over-month revenue growth using LAG() window function, plus running cumulative revenue. Very common interview question pattern.</div>
    </div>
    <div class="code-block">
      <div class="code-header"><span class="code-lang">SQL — Monthly Revenue with MoM Growth</span><button class="copy-btn" onclick="copyCode(this)">Copy</button></div>
      <pre><code><span class="cm">-- CTE 1: Aggregate revenue by month</span>
<span class="kw">WITH</span> monthly_revenue <span class="kw">AS</span> (
    <span class="kw">SELECT</span>
        year, month,
        <span class="fn">SUM</span>(net_revenue)              <span class="kw">AS</span> total_revenue,
        <span class="fn">COUNT</span>(order_id)               <span class="kw">AS</span> order_count,
        <span class="fn">COUNT</span>(<span class="kw">DISTINCT</span> customer_id)   <span class="kw">AS</span> unique_customers,
        <span class="fn">AVG</span>(shipping_days)            <span class="kw">AS</span> avg_shipping_days
    <span class="kw">FROM</span> fact_orders
    <span class="kw">WHERE</span> order_status <span class="op">=</span> <span class="st">'Delivered'</span>
    <span class="kw">GROUP BY</span> year, month
),
<span class="cm">-- CTE 2: Add growth metrics using window functions</span>
revenue_with_growth <span class="kw">AS</span> (
    <span class="kw">SELECT</span>
        year, month, total_revenue, order_count,
        <span class="cm">-- LAG: look at the previous row's value</span>
        <span class="fn">LAG</span>(total_revenue) <span class="kw">OVER</span> (<span class="kw">ORDER BY</span> year, month) <span class="kw">AS</span> prev_month_revenue,
        <span class="fn">ROUND</span>(
            (total_revenue - <span class="fn">LAG</span>(total_revenue) <span class="kw">OVER</span> (<span class="kw">ORDER BY</span> year, month))
            / <span class="fn">NULLIF</span>(<span class="fn">LAG</span>(total_revenue) <span class="kw">OVER</span> (<span class="kw">ORDER BY</span> year, month), <span class="nm">0</span>) * <span class="nm">100</span>, <span class="nm">2</span>
        ) <span class="kw">AS</span> mom_growth_pct,
        <span class="cm">-- SUM with frame: running total</span>
        <span class="fn">SUM</span>(total_revenue) <span class="kw">OVER</span> (<span class="kw">ORDER BY</span> year, month) <span class="kw">AS</span> cumulative_revenue
    <span class="kw">FROM</span> monthly_revenue
)
<span class="kw">SELECT</span> * <span class="kw">FROM</span> revenue_with_growth <span class="kw">ORDER BY</span> year, month;</code></pre>
    </div>
  </div>

  <div class="tab-panel" id="tab-q2">
    <div class="callout callout-info">
      <div class="callout-icon">💡</div>
      <div><strong>What this shows:</strong> Cohort retention — groups customers by the month they first ordered, then tracks what % came back in each subsequent month. This is a senior-level analytics pattern.</div>
    </div>
    <div class="code-block">
      <div class="code-header"><span class="code-lang">SQL — Customer Cohort Retention</span><button class="copy-btn" onclick="copyCode(this)">Copy</button></div>
      <pre><code><span class="kw">WITH</span> first_purchase <span class="kw">AS</span> (
    <span class="kw">SELECT</span>
        customer_id,
        <span class="fn">MIN</span>(<span class="fn">DATE_TRUNC</span>(<span class="st">'month'</span>, order_date_ts)) <span class="kw">AS</span> cohort_month
    <span class="kw">FROM</span> fact_orders
    <span class="kw">WHERE</span> order_status <span class="op">=</span> <span class="st">'Delivered'</span>
    <span class="kw">GROUP BY</span> customer_id
),
cohort_data <span class="kw">AS</span> (
    <span class="kw">SELECT</span>
        fp.cohort_month,
        <span class="fn">DATE_TRUNC</span>(<span class="st">'month'</span>, f.order_date_ts) <span class="kw">AS</span> order_month,
        <span class="fn">COUNT</span>(<span class="kw">DISTINCT</span> f.customer_id)       <span class="kw">AS</span> customers,
        <span class="fn">DATE_DIFF</span>(<span class="st">'month'</span>, fp.cohort_month, <span class="fn">DATE_TRUNC</span>(<span class="st">'month'</span>, f.order_date_ts)) <span class="kw">AS</span> months_since_first
    <span class="kw">FROM</span> fact_orders f
    <span class="kw">JOIN</span> first_purchase fp <span class="kw">ON</span> f.customer_id <span class="op">=</span> fp.customer_id
    <span class="kw">WHERE</span> f.order_status <span class="op">=</span> <span class="st">'Delivered'</span>
    <span class="kw">GROUP BY</span> fp.cohort_month, <span class="fn">DATE_TRUNC</span>(<span class="st">'month'</span>, f.order_date_ts)
)
<span class="kw">SELECT</span>
    cohort_month,
    months_since_first,
    customers,
    <span class="fn">FIRST_VALUE</span>(customers) <span class="kw">OVER</span> (<span class="kw">PARTITION BY</span> cohort_month <span class="kw">ORDER BY</span> months_since_first) <span class="kw">AS</span> cohort_size,
    <span class="fn">ROUND</span>(customers * <span class="nm">100.0</span> /
        <span class="fn">FIRST_VALUE</span>(customers) <span class="kw">OVER</span> (<span class="kw">PARTITION BY</span> cohort_month <span class="kw">ORDER BY</span> months_since_first), <span class="nm">1</span>
    ) <span class="kw">AS</span> retention_pct
<span class="kw">FROM</span> cohort_data
<span class="kw">ORDER BY</span> cohort_month, months_since_first;</code></pre>
    </div>
  </div>

  <div class="tab-panel" id="tab-q3">
    <div class="callout callout-info">
      <div class="callout-icon">💡</div>
      <div><strong>What this shows:</strong> DENSE_RANK vs NTILE — two different ranking functions. DENSE_RANK gives tied items the same rank. NTILE(4) buckets items into quartiles. Common in "top N" type interview questions.</div>
    </div>
    <div class="code-block">
      <div class="code-header"><span class="code-lang">SQL — Category Ranking with DENSE_RANK + NTILE</span><button class="copy-btn" onclick="copyCode(this)">Copy</button></div>
      <pre><code><span class="kw">WITH</span> category_metrics <span class="kw">AS</span> (
    <span class="kw">SELECT</span>
        p.category,
        <span class="fn">COUNT</span>(<span class="kw">DISTINCT</span> f.order_id)  <span class="kw">AS</span> total_orders,
        <span class="fn">SUM</span>(f.net_revenue)          <span class="kw">AS</span> total_revenue,
        <span class="fn">AVG</span>(f.net_revenue)          <span class="kw">AS</span> avg_order_value,
        <span class="fn">ROUND</span>(<span class="fn">SUM</span>(f.refund_amount) / <span class="fn">NULLIF</span>(<span class="fn">SUM</span>(f.net_revenue), <span class="nm">0</span>) * <span class="nm">100</span>, <span class="nm">2</span>) <span class="kw">AS</span> refund_rate_pct
    <span class="kw">FROM</span> fact_orders f
    <span class="kw">JOIN</span> dim_product p <span class="kw">ON</span> f.product_key <span class="op">=</span> p.product_key
    <span class="kw">WHERE</span> f.order_status <span class="op">!=</span> <span class="st">'Cancelled'</span>
    <span class="kw">GROUP BY</span> p.category
)
<span class="kw">SELECT</span>
    category, total_revenue, total_orders, avg_order_value, refund_rate_pct,
    <span class="cm">-- Same rank for ties, no gaps</span>
    <span class="fn">DENSE_RANK</span>() <span class="kw">OVER</span> (<span class="kw">ORDER BY</span> total_revenue <span class="kw">DESC</span>)   <span class="kw">AS</span> revenue_rank,
    <span class="cm">-- Bucket into 4 equal groups</span>
    <span class="fn">NTILE</span>(<span class="nm">4</span>)      <span class="kw">OVER</span> (<span class="kw">ORDER BY</span> total_revenue <span class="kw">DESC</span>)   <span class="kw">AS</span> revenue_quartile,
    <span class="cm">-- Rank by lowest refund rate (quality metric)</span>
    <span class="fn">DENSE_RANK</span>() <span class="kw">OVER</span> (<span class="kw">ORDER BY</span> refund_rate_pct <span class="kw">ASC</span>)   <span class="kw">AS</span> quality_rank
<span class="kw">FROM</span> category_metrics
<span class="kw">ORDER BY</span> revenue_rank;</code></pre>
    </div>
  </div>

  <div class="tab-panel" id="tab-q4">
