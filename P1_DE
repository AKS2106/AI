<!-- ════ STEP 6 ════ -->
<div class="section" id="section-step6">
  <div class="hero">
    <div class="hero-tag">Step 6 · PySpark ETL</div>
    <h1>Core ETL Transformation</h1>
    <p>The heart of the pipeline. Reads raw data, validates it, transforms it into a star schema, and writes Parquet output partitioned by year/month.</p>
  </div>

  <div class="callout callout-info">
    <div class="callout-icon">📖</div>
    <div><strong>Study this file section by section.</strong> This is the file interviewers will ask you to explain. After running it successfully, add your own comment above every function explaining what it does in plain English.</div>
  </div>

  <div class="code-block">
    <div class="code-header"><span class="code-lang">scripts/glue_etl_job.py — Part 1: Setup + Ingest</span><button class="copy-btn" onclick="copyCode(this)">Copy</button></div>
    <pre><code><span class="cm">"""
PySpark ETL Job — E-commerce Order Analytics
Runs locally with: python3 scripts/glue_etl_job.py --env local
Deploy to AWS Glue with: --env glue --bucket your-bucket-name
"""</span>
<span class="kw">import</span> sys, argparse, logging
<span class="kw">from</span> datetime <span class="kw">import</span> datetime
<span class="kw">from</span> pyspark.sql <span class="kw">import</span> SparkSession, DataFrame
<span class="kw">from</span> pyspark.sql <span class="kw">import</span> functions <span class="kw">as</span> F
<span class="kw">from</span> pyspark.sql.types <span class="kw">import</span> DoubleType, IntegerType, StringType

logging.basicConfig(level<span class="op">=</span>logging.INFO, format<span class="op">=</span><span class="st">"%(asctime)s [%(levelname)s] %(message)s"</span>)
log <span class="op">=</span> logging.getLogger(__name__)

parser <span class="op">=</span> argparse.ArgumentParser()
parser.add_argument(<span class="st">"--env"</span>,    default<span class="op">=</span><span class="st">"local"</span>)
parser.add_argument(<span class="st">"--bucket"</span>, default<span class="op">=</span><span class="st">"ecom-pipeline-yourname-2024"</span>)
args, _ <span class="op">=</span> parser.parse_known_args()

RAW_BASE <span class="op">=</span> <span class="st">"data/raw"</span>       <span class="kw">if</span> args.env <span class="op">==</span> <span class="st">"local"</span> <span class="kw">else</span> <span class="st">f"s3://{args.bucket}/raw"</span>
OUT_BASE <span class="op">=</span> <span class="st">"data/processed"</span>  <span class="kw">if</span> args.env <span class="op">==</span> <span class="st">"local"</span> <span class="kw">else</span> <span class="st">f"s3://{args.bucket}/processed"</span>

spark <span class="op">=</span> (
    SparkSession.builder.appName(<span class="st">"ecom-etl"</span>)
    .master(<span class="st">"local[*]"</span>)  <span class="cm"># uses all CPU cores locally</span>
    .config(<span class="st">"spark.sql.adaptive.enabled"</span>, <span class="st">"true"</span>)      <span class="cm"># AQE: auto-optimizes joins</span>
    .config(<span class="st">"spark.sql.shuffle.partitions"</span>, <span class="st">"8"</span>)       <span class="cm"># low for local dev (default is 200)</span>
    .config(<span class="st">"spark.sql.parquet.compression.codec"</span>, <span class="st">"snappy"</span>)
    .getOrCreate()
)
spark.sparkContext.setLogLevel(<span class="st">"WARN"</span>)

<span class="cm"># ── INGEST ──────────────────────────────────────────────</span>
<span class="kw">def</span> <span class="fn">ingest_orders</span>() <span class="op">-></span> DataFrame:
    log.info(<span class="st">"Ingesting orders..."</span>)
    df <span class="op">=</span> spark.read.option(<span class="st">"header"</span>, <span class="st">"true"</span>).option(<span class="st">"inferSchema"</span>, <span class="st">"true"</span>).csv(<span class="st">f"{RAW_BASE}/orders/"</span>)
    log.info(<span class="st">f"  → {df.count()} raw orders"</span>)
    <span class="kw">return</span> df

<span class="kw">def</span> <span class="fn">ingest_returns</span>() <span class="op">-></span> DataFrame:
    log.info(<span class="st">"Ingesting returns..."</span>)
    <span class="kw">return</span> spark.read.option(<span class="st">"multiline"</span>, <span class="st">"true"</span>).json(<span class="st">f"{RAW_BASE}/returns/"</span>)

<span class="kw">def</span> <span class="fn">ingest_events</span>() <span class="op">-></span> DataFrame:
    log.info(<span class="st">"Ingesting events..."</span>)
    <span class="kw">return</span> spark.read.option(<span class="st">"multiline"</span>, <span class="st">"true"</span>).json(<span class="st">f"{RAW_BASE}/events/"</span>)</code></pre>
  </div>

  <div class="code-block">
    <div class="code-header"><span class="code-lang">scripts/glue_etl_job.py — Part 2: Quality + Transform</span><button class="copy-btn" onclick="copyCode(this)">Copy</button></div>
    <pre><code><span class="cm"># ── DATA QUALITY ────────────────────────────────────────</span>
<span class="kw">def</span> <span class="fn">run_quality_checks</span>(df, table_name, checks):
    <span class="st">"""Validates rules, marks bad rows as invalid, logs results."""</span>
    total <span class="op">=</span> df.count()
    df    <span class="op">=</span> df.withColumn(<span class="st">"_is_valid"</span>, F.lit(<span class="kw">True</span>))
    df    <span class="op">=</span> df.withColumn(<span class="st">"_failed_checks"</span>, F.lit(<span class="st">""</span>))

    <span class="kw">for</span> name, condition <span class="kw">in</span> checks.items():
        failed <span class="op">=</span> df.filter(<span class="op">~</span>condition).count()
        log.info(<span class="st">f"  {name}: {failed}/{total} failed ({round(failed/total*100,1)}%)"</span>)
        df <span class="op">=</span> df.withColumn(<span class="st">"_is_valid"</span>,
            F.when(<span class="op">~</span>condition, F.lit(<span class="kw">False</span>)).otherwise(F.col(<span class="st">"_is_valid"</span>)))
        df <span class="op">=</span> df.withColumn(<span class="st">"_failed_checks"</span>,
            F.when(<span class="op">~</span>condition, F.concat(F.col(<span class="st">"_failed_checks"</span>), F.lit(<span class="st">f"|{name}"</span>)))
            .otherwise(F.col(<span class="st">"_failed_checks"</span>)))

    valid   <span class="op">=</span> df.filter(F.col(<span class="st">"_is_valid"</span>)).count()
    log.info(<span class="st">f"  → {valid} valid, {total-valid} quarantined"</span>)
    <span class="kw">return</span> df

<span class="cm"># ── DIM DATE ────────────────────────────────────────────</span>
<span class="kw">def</span> <span class="fn">build_dim_date</span>():
    <span class="cm"># Generate a row for every day in 2024 using Spark's sequence function</span>
    dates_df <span class="op">=</span> spark.sql(<span class="st">"""
        SELECT explode(sequence(to_date('2024-01-01'), to_date('2024-12-31'),
                                interval 1 day)) AS full_date
    """</span>)
    <span class="kw">return</span> dates_df.select(
        F.date_format(<span class="st">"full_date"</span>, <span class="st">"yyyyMMdd"</span>).cast(IntegerType()).alias(<span class="st">"date_key"</span>),
        F.col(<span class="st">"full_date"</span>),
        F.year(<span class="st">"full_date"</span>).alias(<span class="st">"year"</span>),
        F.quarter(<span class="st">"full_date"</span>).alias(<span class="st">"quarter"</span>),
        F.month(<span class="st">"full_date"</span>).alias(<span class="st">"month"</span>),
        F.date_format(<span class="st">"full_date"</span>, <span class="st">"MMMM"</span>).alias(<span class="st">"month_name"</span>),
        F.dayofweek(<span class="st">"full_date"</span>).alias(<span class="st">"day_of_week"</span>),
        F.date_format(<span class="st">"full_date"</span>, <span class="st">"EEEE"</span>).alias(<span class="st">"day_name"</span>),
        F.when(F.dayofweek(<span class="st">"full_date"</span>).isin([<span class="nm">1</span>, <span class="nm">7</span>]), <span class="kw">True</span>).otherwise(<span class="kw">False</span>).alias(<span class="st">"is_weekend"</span>),
        F.lit(<span class="kw">False</span>).alias(<span class="st">"is_holiday"</span>),
    )

<span class="cm"># ── FACT ORDERS ─────────────────────────────────────────</span>
<span class="kw">def</span> <span class="fn">build_fact_orders</span>(orders_df, returns_df):
    clean <span class="op">=</span> orders_df.filter(F.col(<span class="st">"_is_valid"</span>)).drop(<span class="st">"_is_valid"</span>, <span class="st">"_failed_checks"</span>)
    clean <span class="op">=</span> (clean
        .withColumn(<span class="st">"order_date_ts"</span>,  F.to_timestamp(<span class="st">"order_date"</span>, <span class="st">"yyyy-MM-dd HH:mm:ss"</span>))
        .withColumn(<span class="st">"order_date_key"</span>, F.date_format(<span class="st">"order_date_ts"</span>, <span class="st">"yyyyMMdd"</span>).cast(IntegerType()))
        .withColumn(<span class="st">"order_amount"</span>,   F.col(<span class="st">"order_amount"</span>).cast(DoubleType()))
        .withColumn(<span class="st">"quantity"</span>,       F.col(<span class="st">"quantity"</span>).cast(IntegerType()))
        .withColumn(<span class="st">"gross_revenue"</span>,  F.round(F.col(<span class="st">"quantity"</span>) <span class="op">*</span> F.col(<span class="st">"unit_price"</span>), <span class="nm">2</span>))
        .withColumn(<span class="st">"net_revenue"</span>,    F.col(<span class="st">"order_amount"</span>))
        .withColumn(<span class="st">"discount_amount"</span>, F.round(F.col(<span class="st">"gross_revenue"</span>) <span class="op">-</span> F.col(<span class="st">"net_revenue"</span>), <span class="nm">2</span>))
        .withColumn(<span class="st">"customer_key"</span>,   F.md5(F.col(<span class="st">"customer_id"</span>)))
        .withColumn(<span class="st">"product_key"</span>,    F.md5(F.col(<span class="st">"product_id"</span>)))
        .withColumn(<span class="st">"order_key"</span>,      F.md5(F.col(<span class="st">"order_id"</span>)))
    )
    ret_clean <span class="op">=</span> (returns_df.filter(F.col(<span class="st">"_is_valid"</span>))
        .select(F.col(<span class="st">"order_id"</span>).alias(<span class="st">"ret_order_id"</span>), <span class="st">"refund_amount"</span>))

    fact <span class="op">=</span> (clean.join(ret_clean, clean.order_id <span class="op">==</span> ret_clean.ret_order_id, <span class="st">"left"</span>)
        .withColumn(<span class="st">"is_returned"</span>,  F.col(<span class="st">"ret_order_id"</span>).isNotNull())
        .withColumn(<span class="st">"refund_amount"</span>, F.coalesce(F.col(<span class="st">"refund_amount"</span>), F.lit(<span class="nm">0.0</span>)))
        .withColumn(<span class="st">"year"</span>,  F.year(<span class="st">"order_date_ts"</span>))
        .withColumn(<span class="st">"month"</span>, F.month(<span class="st">"order_date_ts"</span>))
        .withColumn(<span class="st">"etl_inserted_at"</span>, F.current_timestamp())
    )
    log.info(<span class="st">f"  → {fact.count()} fact rows"</span>)
    <span class="kw">return</span> fact

<span class="cm"># ── WRITE ───────────────────────────────────────────────</span>
<span class="kw">def</span> <span class="fn">write_table</span>(df, name, partition_cols<span class="op">=</span><span class="kw">None</span>):
    path   <span class="op">=</span> <span class="st">f"{OUT_BASE}/{name}"</span>
    writer <span class="op">=</span> df.coalesce(<span class="nm">1</span>).write.mode(<span class="st">"overwrite"</span>).format(<span class="st">"parquet"</span>)
    <span class="kw">if</span> partition_cols:
        writer <span class="op">=</span> writer.partitionBy(<span class="op">*</span>partition_cols)
    writer.save(path)
    log.info(<span class="st">f"  ✓ Written: {path}"</span>)

<span class="cm"># ── MAIN ────────────────────────────────────────────────</span>
<span class="kw">def</span> <span class="fn">main</span>():
    log.info(<span class="st">"ETL Job started"</span>)
    orders_raw  <span class="op">=</span> ingest_orders()
    returns_raw <span class="op">=</span> ingest_returns()

    orders_qc <span class="op">=</span> run_quality_checks(orders_raw, <span class="st">"orders"</span>, {
        <span class="st">"order_id_not_null"</span>:     F.col(<span class="st">"order_id"</span>).isNotNull(),
        <span class="st">"customer_id_not_null"</span>:  F.col(<span class="st">"customer_id"</span>).isNotNull(),
        <span class="st">"amount_positive"</span>:       F.col(<span class="st">"order_amount"</span>).cast(DoubleType()) <span class="op">></span> <span class="nm">0</span>,
        <span class="st">"quantity_positive"</span>:     F.col(<span class="st">"quantity"</span>).cast(IntegerType()) <span class="op">></span> <span class="nm">0</span>,
    })
    returns_qc <span class="op">=</span> run_quality_checks(returns_raw, <span class="st">"returns"</span>, {
        <span class="st">"return_id_not_null"</span>:  F.col(<span class="st">"return_id"</span>).isNotNull(),
        <span class="st">"refund_positive"</span>:     F.col(<span class="st">"refund_amount"</span>).cast(DoubleType()) <span class="op">>=</span> <span class="nm">0</span>,
    })

    dim_date    <span class="op">=</span> build_dim_date()
    fact_orders <span class="op">=</span> build_fact_orders(orders_qc, returns_qc)

    write_table(dim_date,    <span class="st">"dim_date"</span>)
    write_table(fact_orders, <span class="st">"fact_orders"</span>, [<span class="st">"year"</span>, <span class="st">"month"</span>])
    log.info(<span class="st">"✅ ETL Job complete"</span>)

<span class="kw">if</span> __name__ <span class="op">==</span> <span class="st">"__main__"</span>:
    main()</code></pre>
  </div>

