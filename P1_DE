<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>DE Project 1 — E-commerce Pipeline</title>
<style>
  :root {
    --bg: #0f1117;
    --bg2: #1a1d27;
    --bg3: #22263a;
    --card: #1e2235;
    --border: #2e3350;
    --accent: #6c63ff;
    --accent2: #00d4aa;
    --accent3: #ff6b6b;
    --accent4: #ffd166;
    --text: #e8eaf0;
    --text2: #9aa0b8;
    --text3: #6b7399;
    --code-bg: #13151f;
    --green: #00d4aa;
    --red: #ff6b6b;
    --yellow: #ffd166;
    --purple: #6c63ff;
    --blue: #4fc3f7;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 15px;
    line-height: 1.7;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    position: fixed; top: 0; left: 0;
    width: 260px; height: 100vh;
    background: var(--bg2);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    z-index: 100;
    transition: transform 0.3s;
  }
  .sidebar-logo {
    padding: 20px 20px 16px;
    border-bottom: 1px solid var(--border);
  }
  .sidebar-logo .proj-tag {
    font-size: 10px; font-weight: 700; letter-spacing: 2px;
    color: var(--accent); text-transform: uppercase; margin-bottom: 4px;
  }
  .sidebar-logo h2 { font-size: 13px; color: var(--text); font-weight: 600; line-height: 1.4; }
  .sidebar-section { padding: 12px 0; border-bottom: 1px solid var(--border); }
  .sidebar-section-label {
    font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
    color: var(--text3); text-transform: uppercase;
    padding: 0 20px 8px;
  }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 20px; cursor: pointer;
    color: var(--text2); font-size: 13px;
    border-left: 3px solid transparent;
    transition: all 0.15s;
    text-decoration: none;
  }
  .nav-item:hover { color: var(--text); background: var(--bg3); }
  .nav-item.active { color: var(--accent); border-left-color: var(--accent); background: rgba(108,99,255,0.08); }
  .nav-dot {
    width: 22px; height: 22px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 700; flex-shrink: 0;
    background: var(--bg3); color: var(--text3);
  }
  .nav-item.done .nav-dot { background: rgba(0,212,170,0.15); color: var(--green); }
  .nav-item.active .nav-dot { background: rgba(108,99,255,0.2); color: var(--accent); }

  .progress-bar {
    margin: 12px 20px;
    height: 4px; border-radius: 2px;
    background: var(--border); overflow: hidden;
  }
  .progress-fill {
    height: 100%; border-radius: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    transition: width 0.4s;
  }
  .progress-label { font-size: 11px; color: var(--text3); padding: 0 20px 8px; }

  /* ── MAIN ── */
  .main { margin-left: 260px; min-height: 100vh; }
  .topbar {
    position: sticky; top: 0; z-index: 50;
    background: rgba(15,17,23,0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    padding: 12px 32px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .topbar-left { display: flex; align-items: center; gap: 12px; }
  .section-badge {
    font-size: 11px; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase; padding: 3px 10px; border-radius: 20px;
  }
  .badge-setup  { background: rgba(79,195,247,0.15); color: var(--blue); }
  .badge-code   { background: rgba(108,99,255,0.15); color: var(--purple); }
  .badge-sql    { background: rgba(0,212,170,0.15);  color: var(--green); }
  .badge-interview { background: rgba(255,209,102,0.15); color: var(--yellow); }
  .badge-arch   { background: rgba(255,107,107,0.15); color: var(--red); }

  .menu-btn {
    display: none; background: none; border: none;
    color: var(--text2); cursor: pointer; font-size: 20px; padding: 4px;
  }

  .content { padding: 32px; max-width: 900px; }

  /* ── SECTIONS ── */
  .section { display: none; }
  .section.active { display: block; }

  /* ── HERO ── */
  .hero {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px; padding: 32px;
    margin-bottom: 28px;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; top: -60px; right: -60px;
    width: 220px; height: 220px; border-radius: 50%;
    background: radial-gradient(circle, rgba(108,99,255,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-tag {
    font-size: 11px; font-weight: 700; letter-spacing: 2px;
    text-transform: uppercase; color: var(--accent);
    margin-bottom: 10px;
  }
  .hero h1 { font-size: 26px; font-weight: 700; margin-bottom: 10px; line-height: 1.3; }
  .hero p  { color: var(--text2); font-size: 14px; margin-bottom: 20px; max-width: 600px; }
  .hero-stats {
    display: flex; gap: 24px; flex-wrap: wrap;
  }
  .stat { text-align: left; }
  .stat-val { font-size: 22px; font-weight: 700; color: var(--accent2); }
  .stat-label { font-size: 11px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.5px; }

  /* ── STEP CARDS ── */
  .step-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px; margin-bottom: 20px;
    overflow: hidden;
  }
  .step-header {
    display: flex; align-items: center; gap: 14px;
    padding: 18px 22px; cursor: pointer;
    transition: background 0.15s;
  }
  .step-header:hover { background: rgba(255,255,255,0.02); }
  .step-num {
    width: 36px; height: 36px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; flex-shrink: 0;
    background: var(--bg3); color: var(--text2);
    border: 1px solid var(--border);
  }
  .step-num.done { background: rgba(0,212,170,0.15); color: var(--green); border-color: rgba(0,212,170,0.3); }
  .step-num.active-step { background: rgba(108,99,255,0.2); color: var(--accent); border-color: rgba(108,99,255,0.4); }
  .step-title { font-size: 15px; font-weight: 600; }
  .step-subtitle { font-size: 12px; color: var(--text3); margin-top: 2px; }
  .step-time {
    margin-left: auto; font-size: 11px; color: var(--text3);
    background: var(--bg3); padding: 3px 10px; border-radius: 20px;
    flex-shrink: 0;
  }
  .step-chevron { margin-left: 8px; color: var(--text3); font-size: 12px; transition: transform 0.2s; flex-shrink: 0; }
  .step-body { display: none; padding: 0 22px 22px; border-top: 1px solid var(--border); }
  .step-body.open { display: block; }
  .step-body p { color: var(--text2); font-size: 14px; margin: 14px 0 10px; }
  .step-body ul, .step-body ol { color: var(--text2); font-size: 14px; padding-left: 20px; margin: 8px 0; }
  .step-body li { margin-bottom: 6px; }

  /* ── CODE BLOCKS ── */
  .code-block { position: relative; margin: 14px 0; border-radius: 10px; overflow: hidden; }
  .code-header {
    background: #0d0f1a; padding: 8px 16px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--border);
  }
  .code-lang {
    font-size: 11px; font-weight: 600; letter-spacing: 1px;
    text-transform: uppercase; color: var(--text3);
  }
  .copy-btn {
    background: var(--bg3); border: 1px solid var(--border);
    color: var(--text2); font-size: 11px; padding: 4px 12px;
    border-radius: 6px; cursor: pointer; transition: all 0.15s;
    font-family: inherit;
  }
  .copy-btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
  .copy-btn.copied { background: rgba(0,212,170,0.2); color: var(--green); border-color: var(--green); }
  pre {
    background: var(--code-bg); padding: 18px;
    overflow-x: auto; font-size: 13px; line-height: 1.7;
    font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
  }
  pre code { color: #c9d1d9; }
  .kw { color: #ff79c6; }
  .fn { color: #50fa7b; }
  .st { color: #f1fa8c; }
  .cm { color: #6272a4; font-style: italic; }
  .nm { color: #bd93f9; }
  .op { color: #ff79c6; }

  /* ── CALLOUTS ── */
  .callout {
    border-radius: 10px; padding: 14px 18px;
    margin: 14px 0; font-size: 14px;
    display: flex; gap: 12px; align-items: flex-start;
  }
  .callout-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
  .callout-tip { background: rgba(0,212,170,0.08); border: 1px solid rgba(0,212,170,0.2); color: #a8f0e0; }
  .callout-warn { background: rgba(255,209,102,0.08); border: 1px solid rgba(255,209,102,0.2); color: #ffe8a0; }
  .callout-info { background: rgba(108,99,255,0.08); border: 1px solid rgba(108,99,255,0.2); color: #c4c0ff; }
  .callout-danger { background: rgba(255,107,107,0.08); border: 1px solid rgba(255,107,107,0.2); color: #ffb3b3; }

  /* ── CHECKLIST ── */
  .checklist { list-style: none; padding: 0; margin: 14px 0; }
  .checklist li {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 8px 0; border-bottom: 1px solid var(--border);
    font-size: 14px; color: var(--text2);
  }
  .checklist li:last-child { border-bottom: none; }
  .checklist input[type=checkbox] {
    width: 16px; height: 16px; accent-color: var(--accent);
    cursor: pointer; flex-shrink: 0; margin-top: 3px;
  }
  .checklist label { cursor: pointer; }
  .checklist input:checked + label { text-decoration: line-through; color: var(--text3); }

  /* ── INTERVIEW CARDS ── */
  .q-card {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 10px; margin-bottom: 12px; overflow: hidden;
  }
  .q-header {
    padding: 14px 18px; cursor: pointer;
    display: flex; align-items: flex-start; gap: 12px;
    transition: background 0.15s;
  }
  .q-header:hover { background: rgba(255,255,255,0.02); }
  .q-num {
    font-size: 11px; font-weight: 700; color: var(--accent);
    background: rgba(108,99,255,0.15); padding: 2px 8px;
    border-radius: 10px; flex-shrink: 0; margin-top: 2px;
  }
  .q-cat {
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase; padding: 2px 8px; border-radius: 10px;
    flex-shrink: 0; margin-top: 2px;
  }
  .cat-arch { background: rgba(255,107,107,0.15); color: var(--red); }
  .cat-spark { background: rgba(108,99,255,0.15); color: var(--purple); }
  .cat-dq { background: rgba(0,212,170,0.15); color: var(--green); }
  .cat-sql { background: rgba(79,195,247,0.15); color: var(--blue); }
  .cat-prod { background: rgba(255,209,102,0.15); color: var(--yellow); }
  .q-text { font-size: 14px; font-weight: 500; color: var(--text); flex: 1; }
  .q-body {
    display: none; padding: 0 18px 18px;
    border-top: 1px solid var(--border);
  }
  .q-body.open { display: block; }
  .q-body p { font-size: 14px; color: var(--text2); margin-top: 12px; }
  .answer-label {
    font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--accent2); margin-top: 14px; margin-bottom: 6px;
  }

  /* ── ARCH DIAGRAM ── */
  .arch-diagram {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 12px; padding: 24px;
    margin: 16px 0; overflow-x: auto;
  }
  .arch-flow {
    display: flex; align-items: center; gap: 0;
    flex-wrap: wrap; justify-content: center;
  }
  .arch-box {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 10px; padding: 12px 16px; text-align: center;
    min-width: 100px;
  }
  .arch-box .box-icon { font-size: 22px; margin-bottom: 4px; }
  .arch-box .box-title { font-size: 12px; font-weight: 600; color: var(--text); }
  .arch-box .box-sub { font-size: 10px; color: var(--text3); margin-top: 2px; }
  .arch-box.highlight { border-color: var(--accent); background: rgba(108,99,255,0.1); }
  .arch-arrow { color: var(--text3); font-size: 18px; padding: 0 8px; flex-shrink: 0; }

  /* ── SCHEMA TABLE ── */
  .schema-table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 13px; }
  .schema-table th {
    background: var(--bg3); color: var(--text2); font-weight: 600;
    padding: 10px 14px; text-align: left;
    border-bottom: 1px solid var(--border);
  }
  .schema-table td {
    padding: 9px 14px; border-bottom: 1px solid rgba(46,51,80,0.5);
    color: var(--text2); vertical-align: top;
  }
  .schema-table tr:hover td { background: rgba(255,255,255,0.02); }
  .col-pk { color: var(--yellow); font-weight: 600; font-size: 10px; }
  .col-fk { color: var(--blue); font-weight: 600; font-size: 10px; }
  .col-type { color: var(--accent2); font-size: 12px; font-family: monospace; }

  /* ── RESUME BOX ── */
  .resume-box {
    background: rgba(0,212,170,0.06);
    border: 1px solid rgba(0,212,170,0.2);
    border-radius: 12px; padding: 22px;
    margin: 16px 0;
  }
  .resume-box h4 { color: var(--accent2); font-size: 13px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 1px; }
  .resume-box p { color: #a8f0e0; font-size: 14px; line-height: 1.8; }

  /* ── TIMELINE ── */
  .timeline { margin: 16px 0; }
  .tl-item {
    display: flex; gap: 16px; margin-bottom: 16px;
    align-items: flex-start;
  }
  .tl-left { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
  .tl-dot {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--bg3); border: 2px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: var(--text3);
  }
  .tl-dot.green { border-color: var(--green); color: var(--green); background: rgba(0,212,170,0.1); }
  .tl-dot.purple { border-color: var(--purple); color: var(--purple); background: rgba(108,99,255,0.1); }
  .tl-dot.yellow { border-color: var(--yellow); color: var(--yellow); background: rgba(255,209,102,0.1); }
  .tl-line { width: 2px; flex: 1; background: var(--border); min-height: 20px; margin: 4px 0; }
  .tl-content { flex: 1; padding-bottom: 4px; }
  .tl-title { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 3px; }
  .tl-desc { font-size: 13px; color: var(--text3); }
  .tl-time { font-size: 11px; color: var(--accent); margin-top: 3px; }

  /* ── TABS ── */
  .tabs { display: flex; gap: 4px; margin-bottom: 16px; flex-wrap: wrap; }
  .tab-btn {
    padding: 7px 16px; border-radius: 8px; cursor: pointer;
    font-size: 13px; font-weight: 500;
    background: var(--bg3); border: 1px solid var(--border);
    color: var(--text2); transition: all 0.15s; font-family: inherit;
  }
  .tab-btn:hover { border-color: var(--accent); color: var(--accent); }
  .tab-btn.active { background: rgba(108,99,255,0.2); border-color: var(--accent); color: var(--accent); }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* ── MISC ── */
  h3 { font-size: 17px; font-weight: 600; margin: 22px 0 12px; color: var(--text); }
  h3:first-child { margin-top: 14px; }
  .tag {
    display: inline-block; font-size: 11px; font-weight: 600;
    padding: 2px 8px; border-radius: 6px; margin-right: 6px; margin-bottom: 4px;
  }
  .tag-aws { background: rgba(255,153,0,0.15); color: #ffaa44; }
  .tag-py  { background: rgba(79,195,247,0.15); color: var(--blue); }
  .tag-sql { background: rgba(0,212,170,0.15);  color: var(--green); }
  .tag-spark { background: rgba(255,107,107,0.15); color: var(--red); }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .sidebar { transform: translateX(-100%); }
    .sidebar.open { transform: translateX(0); }
    .main { margin-left: 0; }
    .menu-btn { display: block; }
    .content { padding: 20px 16px; }
    .hero h1 { font-size: 20px; }
    .hero-stats { gap: 16px; }
    .arch-flow { gap: 8px; }
    .topbar { padding: 10px 16px; }
  }

  .overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.6); z-index: 99;
  }
  .overlay.show { display: block; }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text3); }
</style>
</head>
